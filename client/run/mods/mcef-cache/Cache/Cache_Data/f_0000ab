function validPerNumber(tagId, warnTagId, isNullable) {
  $("#infoShow").text("");
  var v_card = $.trim($("#" + tagId).val());
  if (isNullable && v_card.length <= 0) {
    removeWarnInfo(warnTagId);
    return true;
  }
  var reg = /^\d{17}([0-9Xx])$/;
  if (!isNotValid(v_card == "", warnTagId, "请输入你的身份证号码！")) {
    return false;
  }
  if (!isNotValid(!reg.test(v_card), warnTagId, "身份证号码输入错误！")) {
    return false;
  }

  var area = {
    11: "北京市",
    12: "天津市",
    13: "河北省",
    14: "山西省",
    15: "内蒙古自治区",
    21: "辽宁省",
    22: "吉林省",
    23: "黑龙江省",
    31: "上海市",
    32: "江苏省",
    33: "浙江省",
    34: "安徽省",
    35: "福建省",
    36: "江西省",
    37: "山东省",
    41: "河南省",
    42: "湖北省",
    43: "湖南省",
    44: "广东省",
    45: "广西壮族自治区",
    46: "海南省",
    50: "重庆市",
    51: "四川省",
    52: "贵州省",
    53: "云南省",
    54: "西藏自治区",
    61: "陕西省",
    62: "甘肃省",
    63: "青海省",
    64: "宁夏回族自治区",
    65: "新疆维吾尔自治区"
  };

  if (
    !isNotValid(
      area[parseInt(v_card.substr(0, 2))] == null,
      warnTagId,
      "身份证号码地区码错误！"
    )
  ) {
    return false;
  }

  if (v_card.length == 18) {
    var n = new Date();
    var y = n.getFullYear();
    if (
      !isNotValid(
        parseInt(v_card.substr(6, 4)) < 1900 ||
          parseInt(v_card.substr(6, 4)) > y,
        warnTagId,
        "身份证号码输入错误！"
      )
    ) {
      return false;
    }
    var birth =
      v_card.substr(6, 4) +
      "-" +
      v_card.substr(10, 2) +
      "-" +
      v_card.substr(12, 2);
    if (!isNotValid(!isDate(birth), warnTagId, "身份证号码输入错误！")) {
