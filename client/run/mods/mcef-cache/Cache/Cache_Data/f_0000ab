// 验证新密码
function validPwd(pid, pInfoid, isNullable) {
  var ddNumPVal = $("#" + pid).val();
  if (ddNumPVal.length == 0 && isNullable) {
    removeWarnInfo(pInfoid);
    return true;
  }
  if (!isNotValid(ddNumPVal.length == 0, pInfoid, "请输入你的密码！")) {
    return false;
  }
  if (
    !isNotValid(
      !passwordCheckV1(ddNumPVal),
      pInfoid,
      __TIPS.inValidPasswordTips
    )
  ) {
    return false;
  }

  var instance = new WeakPasswordChecker();
  var isWeak = instance.isWeak(ddNumPVal);
  if (
    !isNotValid(
      isWeak == true,
      pInfoid,
      "这个密码太简单容易被盗号哦，换一个吧~~"
    )
  ) {
    return false;
  }
  return true;
}

