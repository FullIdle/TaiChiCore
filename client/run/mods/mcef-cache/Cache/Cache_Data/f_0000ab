/*手机号码验证*/
function DoValid(id, tipId, type) {
  var val = $.trim($(id).val()),
    flag = false;
  if (type == "phone") {
    if (!isMobile(val)) {
      $(tipId).html("请输入正确的手机号码！");
      flag = true;
    }
  } else if (type == "email") {
    if (!isEmail(val)) {
      $(tipId).html("请输入正确的电子邮箱！");
      flag = true;
    }
  } else if (type == "phoneValidCode") {
    if (val.length == 0) {
      $(tipId).html("请输入手机验证码！");
      flag = true;
    }
  } else if (type == "validCode") {
    if (val.length == 0) {
      $(tipId).html("请输入验证码！");
      flag = true;
    }
  }
  if (flag) {
    $(tipId).addClass("no");
    return false;
  }
  $(tipId).html("");
  $(tipId).removeClass("no");
  $(tipId).html('<img src="/images/account_validate_ok.png" />');
  return true;
}
