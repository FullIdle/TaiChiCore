/**
 * @param {string} str
 * @return {boolean}
 */
function passwordCheckV1(str) {
  // 判空
  if (!str || !str.length) {
    return false;
  }
  // 判空格
  if (/\s/.test(str)) {
    return false;
  }
  // 有效字符,长度8-16
  if (!/^[0-9a-zA-Z!@#$%^&*()/~<>?_\-+=]{8,16}$/.test(str)) {
    return false;
  }
  var numReg = /[0-9]/;
  var letterReg = /[a-zA-Z]/;
  var specialSymbolReg = /[!@#$%^&*()/~<>?_\-+=]/;
  // 至少两种组合 A32
  if (numReg.test(str) && letterReg.test(str)) {
    return true;
  }
  if (numReg.test(str) && specialSymbolReg.test(str)) {
    return true;
  }
  if (letterReg.test(str) && specialSymbolReg.test(str)) {
    return true;
  }
  return false;
}

