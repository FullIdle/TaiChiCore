// 验证账号
function validAccount() {
  var account = $.trim($("#ddNum").val());
  if (!isNotValid(account.length == 0, "ddNumShow", "你还没填账号哦！")) {
    return false;
  }
  if (!isNaN(account)) {
    if (account.length <= 4) {
      warnInfo("ddNumShow", "请输入正确的多多号！");
      return false;
    }
    if (account.length < 11) {
      return true;
    }
    if (account.length > 11) {
      warnInfo("ddNumShow", "请输入正确的手机号！");
      return false;
    }
    $.post(
      "/checkMobileExist.action",
      { mobileNo: account },
      function (data) {
        if (data.resultCode.code == 0) {
          warnInfo("ddNumShow", "该手机号没有被绑定！请更换一个！");
          return false;
        } else if (data.resultCode.code == -22) {
          warnInfo("ddNumShow", "请求太频繁，请稍后重试");
          return false;
        } else {
          return true;
        }
      },
      "json"
    );
  } else if (isEmail(account)) {
    $.post(
      "/checkEmailExist.action",
      { email: account },
      function (data) {
        if (data.resultCode.code == 0) {
          warnInfo("ddNumShow", "该邮箱没有被绑定！请更换一个！");
          return false;
        } else {
          return true;
        }
      },
      "json"
    );
  } else {
    warnInfo("ddNumShow", "请输入正确的邮箱地址！");
    return false;
  }
}

