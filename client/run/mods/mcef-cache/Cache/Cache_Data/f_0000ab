//提醒function
function warnInfo(tagId, warnInfo) {
  $("#" + tagId).html(warnInfo);
  $("#" + tagId).addClass("no");
  return false;
}

function removeWarnInfo(tagId) {
  $("#" + tagId).html("");
  $("#" + tagId).removeClass("no");
}
function isNotValid(condition, warnTagId, info) {
  if (condition) {
    warnInfo(warnTagId, info);
    return false;
  } else {
    removeWarnInfo(warnTagId);
  }
  return true;
}

